---
layout: none
---

{% assign items = "" | split: ',' %}
{% for post in site.posts %}
  {% if post.lang == "简体中文" %}
    {% assign items = items | push: post %}
  {% endif %}
{% endfor %}

{% for page in site.pages %}
  {% if page.lang == "简体中文" and page.title %}
    {% assign items = items | push: page %}
  {% endif %}
{% endfor %}

[
  {% for item in items %}
    {
      "title"    : "{{ item.title | escape }}",
      "lang"     : "{{ item.lang }}",
      "url"      : "{{ site.baseurl }}{{ item.url }}",
      "date"     : "{{ item.date }}",
      "content"  : {{ item.content | strip_html | strip_newlines | jsonify }}
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]